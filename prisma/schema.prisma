generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  uploads Upload[]
  papers  Paper[]
  jobs    Job[]

  @@map("users")
}

model Upload {
  id               String      @id @default(cuid())
  userId           String
  type             UploadType
  originalFilename String
  storagePath      String
  sizeBytes        Int
  uploadedAt       DateTime    @default(now())
  parseStatus      ParseStatus @default(PENDING)
  parsedAt         DateTime?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parsedMessages ParsedMessage[]
  papers         Paper[]
  jobs           Job[]

  @@index([userId])
  @@map("uploads")
}

model ParsedMessage {
  id         String   @id @default(cuid())
  uploadId   String
  speakerId  String
  timestamp  DateTime
  text       String   @db.Text
  lang       String?
  tokenCount Int?
  createdAt  DateTime @default(now())

  upload Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
  @@index([uploadId, timestamp])
  @@map("parsed_messages")
}

model Paper {
  id                 String       @id @default(cuid())
  userId             String
  uploadId           String
  language           Language
  writingStyle       WritingStyle
  status             PaperStatus  @default(PROCESSING)
  title              String?
  abstract           String?      @db.Text
  introduction       String?      @db.Text
  relatedWork        String?      @db.Text
  methods            String?      @db.Text
  results            String?      @db.Text
  discussion         String?      @db.Text
  conclusion         String?      @db.Text
  references         Json?
  appendix           String?      @db.Text
  relationshipType   String?
  relationshipIssues String?      @db.Text
  affectionScores    Json?
  generatedAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  upload  Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  exports      Export[]
  jobs         Job[]
  translations PaperTranslation[]

  @@index([userId])
  @@index([uploadId])
  @@map("papers")
}

model PaperTranslation {
  id           String   @id @default(cuid())
  paperId      String
  language     Language
  title        String?  @db.Text
  abstract     String?  @db.Text
  introduction String?  @db.Text
  methods      String?  @db.Text
  results      String?  @db.Text
  discussion   String?  @db.Text
  conclusion   String?  @db.Text
  createdAt    DateTime @default(now())

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@unique([paperId, language])
  @@index([paperId])
  @@map("paper_translations")
}

model Export {
  id          String       @id @default(cuid())
  paperId     String
  format      ExportFormat
  storagePath String
  sizeBytes   Int?
  createdAt   DateTime     @default(now())

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@map("exports")
}

enum UploadType {
  KAKAO
  AI_CONVERSATION
  INSTAGRAM
  LINE
}

enum ParseStatus {
  PENDING
  PARSING
  COMPLETED
  FAILED
}

enum Language {
  KO
  EN
  JA
}

enum PaperStatus {
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Async Job Pipeline ───────────────────────────────────────────────────────

model Job {
  id             String    @id @default(cuid())
  userId         String
  uploadId       String?
  paperId        String?
  status         JobStatus @default(PENDING)
  progress       Int       @default(0)
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3)
  errorMessage   String?   @db.Text
  errorStack     String?   @db.Text
  idempotencyKey String?   @unique
  enqueuedAt     DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  metadata       Json?

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  upload Upload?  @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  paper  Paper?   @relation(fields: [paperId], references: [id], onDelete: SetNull)
  logs   JobLog[]

  @@index([userId])
  @@index([status])
  @@index([uploadId])
  @@index([idempotencyKey])
  @@map("jobs")
}

model JobLog {
  id        String   @id @default(cuid())
  jobId     String
  level     String
  message   String   @db.Text
  data      Json?
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([jobId, createdAt])
  @@map("job_logs")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum WritingStyle {
  PSYCHOLOGY_PAPER
  COMMUNICATION_ANALYSIS
  RELATIONSHIP_DYNAMICS
  SOCIOLOGY
  BEHAVIORAL_SCIENCE
  COMPUTATIONAL_TEXT
  BIOINFORMATICS
}

enum ExportFormat {
  PDF
  DOCX
}
