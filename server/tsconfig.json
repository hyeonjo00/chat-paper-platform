{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "../dist",
    "baseUrl": "..",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "../server/**/*",
    "../src/lib/nlp/**/*",
    "../src/lib/openai/**/*",
    "../src/types/**/*"
  ],
  "exclude": ["../node_modules", "../src/app", "../src/components", "../src/lib/export"]
}
